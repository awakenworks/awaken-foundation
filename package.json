{
  "name": "awaken-foundation",
  "version": "0.1.0-dev",
  "private": true,
  "packageManager": "pnpm@10.18.1",
  "engines": { "node": ">=20", "pnpm": ">=10" },
  "scripts": {
    "hooks:install": "lefthook install",
    "check": "pnpm check:guardrails && pnpm check:backend",
    "check:guardrails": "cargo run -p xtask -- guardrail-lints",
    "check:backend": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D clippy::correctness && cargo test && cargo deny check"
  },
  "devDependencies": { "lefthook": "^2.1.0" }
}
